<section class="search-panel" data-search-panel hidden aria-label="站内搜索" role="dialog" aria-modal="true">
  <label class="sr-only" for="site-search">搜索笔记</label>
  <input id="site-search" type="search" placeholder="搜索笔记…" autocomplete="off" data-search-input />
  <ul class="search-results" data-search-results aria-live="polite"></ul>
</section>

<script is:inline>
  (() => {
    const panel = document.querySelector('[data-search-panel]');
    const input = document.querySelector('[data-search-input]');
    const results = document.querySelector('[data-search-results]');
    let pagefind;
    const close = () => { panel.hidden = true; };
    const open = async () => {
      panel.hidden = false;
      input.focus();
      try {
        pagefind ||= await import('/pagefind/pagefind.js');
      } catch {
        results.innerHTML = '<li>搜索索引将在站点构建后可用。</li>';
      }
    };
    document.querySelectorAll('[data-search-open]').forEach((button) => button.addEventListener('click', open));
    input.addEventListener('input', async () => {
      const query = input.value.trim();
      if (!query || !pagefind) { results.innerHTML = ''; return; }
      const search = await pagefind.search(query);
      const items = await Promise.all(search.results.slice(0, 8).map(async (result) => ({ result, data: await result.data() })));
      results.replaceChildren(...items.map(({ data }) => {
        const item = document.createElement('li');
        const link = document.createElement('a');
        link.href = data.url; link.textContent = data.meta.title || data.url;
        const excerpt = document.createElement('p'); excerpt.textContent = data.excerpt.replace(/<[^>]*>/g, '');
        item.append(link, excerpt); return item;
      }));
    });
    document.addEventListener('keydown', (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') { event.preventDefault(); open(); }
      if (event.key === 'Escape' && !panel.hidden) close();
    });
    panel.addEventListener('click', (event) => { if (event.target === panel) close(); });
  })();
</script>
