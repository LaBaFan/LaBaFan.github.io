---
interface Link { title: string; href: string; }
interface Props { previous?: Link; next?: Link; }
const { previous, next } = Astro.props;
---
{(previous || next) && <nav class="prev-next" aria-label="相邻笔记">
  {previous ? <a href={previous.href}><small>← 上一篇</small><strong>{previous.title}</strong></a> : <span />}
  {next ? <a href={next.href}><small>下一篇 →</small><strong>{next.title}</strong></a> : <span />}
</nav>}
